block b3 {
    actions {
        addActor(x = 1);
        addActor(x = 2);
        addActor(x = 3);
        addActor(x = 10);
        addActor(x = 20);
        addActor(x = 100);
        addActor(name = "abc");
        addActor(name = "dce");
        addActor(name = "fgh");
    }
}
