//----------------------------------//
//--- AST After forLoopUnrolling ---//
//----------------------------------//
const x = ["abcd","efgh","ijkl"];
def testBool(v) : actions {
    actorTalk(cleanTalk = v);
}
def testInt(v) : actions {
    actorTalk(duration = v);
}
def testString(v) : actions {
    actorTalk(text = v);
}
block init {
    actions {
        testInt(twge::get_length(x));
        testString(twge::get_index(x, 0));
        testInt(twge::get_length(twge::get_index(x, 0)));
        testString(twge::get_index(twge::get_index(x, 0), 0));
        testString(twge::get_index(twge::get_index(x, 0), 1));
        testString(twge::get_index(twge::get_index(x, 0), 2));
        testString(twge::get_index(twge::get_index(x, 0), 3));
        testString(twge::get_index(x, 1));
        testInt(twge::get_length(twge::get_index(x, 1)));
        testString(twge::get_index(twge::get_index(x, 1), 0));
        testString(twge::get_index(twge::get_index(x, 1), 1));
        testString(twge::get_index(twge::get_index(x, 1), 2));
        testString(twge::get_index(twge::get_index(x, 1), 3));
        testString(twge::get_index(x, 2));
        testInt(twge::get_length(twge::get_index(x, 2)));
        testString(twge::get_index(twge::get_index(x, 2), 0));
        testString(twge::get_index(twge::get_index(x, 2), 1));
        testString(twge::get_index(twge::get_index(x, 2), 2));
        testString(twge::get_index(twge::get_index(x, 2), 3));
    }
}
//---------------------------------//
//--- AST After constantFolding ---//
//---------------------------------//
def testBool(v) : actions {
    actorTalk(cleanTalk = v);
}
def testInt(v) : actions {
    actorTalk(duration = v);
}
def testString(v) : actions {
    actorTalk(text = v);
}
block init {
    actions {
        testInt(3);
        testString("abcd");
        testInt(4);
        testString("a");
        testString("b");
        testString("c");
        testString("d");
        testString("efgh");
        testInt(4);
        testString("e");
        testString("f");
        testString("g");
        testString("h");
        testString("ijkl");
        testInt(4);
        testString("i");
        testString("j");
        testString("k");
        testString("l");
    }
}
