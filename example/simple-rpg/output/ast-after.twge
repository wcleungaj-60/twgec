        儲存玩家狀態(category = 狀態讀寫密鑰, key = "STR", playerId = "{instance}", type = "string", value = ("{{instance}." + ("STR" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "CON", playerId = "{instance}", type = "string", value = ("{{instance}." + ("CON" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "AGI", playerId = "{instance}", type = "string", value = ("{{instance}." + ("AGI" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "INT", playerId = "{instance}", type = "string", value = ("{{instance}." + ("INT" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "PSY", playerId = "{instance}", type = "string", value = ("{{instance}." + ("PSY" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "Exp", playerId = "{instance}", type = "string", value = ("{{instance}." + ("Exp" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "HP", playerId = "{instance}", type = "string", value = ("{{instance}." + ("HP" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
