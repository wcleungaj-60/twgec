            光彈特效(fromActor = "instance", scale = "0.5", damage = "{instance.INT} + {instance.PSY}/2 + 10", toAngle = "{instance.bodyRotation}*180/3.14-32");
        }
        if(false) {
            EnhFF::廣義圓形範圍(actorId = "instance", radius = 128, duration = 10000, color = "#D16500", deltaHpType = "heal", deltaHpValue = "1 + {instance.STR}/6 + {instance.CON}/3", deltaHpCD = 1100, deltaHpTarget = ActorMatch(group = 100), lineWidth = 2);
