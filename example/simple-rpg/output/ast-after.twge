block 點擊裝備武器風杖 {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("wear" + "WindStaff"));
    }
    actions {
        人物裝備武器(actorCode = "instance", type = 別名::武器風杖, hand = 1);
        人物裝備武器(actorCode = "instance", type = 別名::武器風杖, hand = 2);
    }
    checks {
    }
}
