block 等級提升 {
    __repeat__ = -1;
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
        比較數字(lhs = "{instance.Exp}", op = ">=", rhs = "{instance.ExpNeeded}");
    }
    actions {
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: green'>Level Up</span>", duration = 6000);
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = "{instance.Exp}-{instance.ExpNeeded}");
        儲存物件變數(key = "Level", object = "instance", type = "integer", value = "{instance.Level}+1");
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{instance.Point}+2");
        儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = "{instance.Level}*2+4");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
