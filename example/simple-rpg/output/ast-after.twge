block 點擊提升一點力量 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = "increaseSTR1");
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = 1);
    }
    actions {
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{instance.Point} - 1");
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = "{instance.STR} + 1");
        角色說話(actorId = "instance", text = "成功提升一點力量，尚餘{instance.Point}點能力點");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = "4-3/(1+0.01*{instance.AGI})");
        設定角色屬性(actorId = "instance", attr = "weight", value = "3*pow(0.97,{instance.AGI})");
        儲存玩家狀態(category = "simple-rpg-test", key = "Point", playerId = "{instance}", type = "string", value = "{{instance}.Point}");
        儲存玩家狀態(category = "simple-rpg-test", key = "ExpNeeded", playerId = "{instance}", type = "string", value = "{{instance}.ExpNeeded}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Level", playerId = "{instance}", type = "string", value = "{{instance}.Level}");
        儲存玩家狀態(category = "simple-rpg-test", key = "STR", playerId = "{instance}", type = "string", value = "{{instance}.STR}");
        儲存玩家狀態(category = "simple-rpg-test", key = "CON", playerId = "{instance}", type = "string", value = "{{instance}.CON}");
        儲存玩家狀態(category = "simple-rpg-test", key = "AGI", playerId = "{instance}", type = "string", value = "{{instance}.AGI}");
        儲存玩家狀態(category = "simple-rpg-test", key = "INT", playerId = "{instance}", type = "string", value = "{{instance}.INT}");
        儲存玩家狀態(category = "simple-rpg-test", key = "PSY", playerId = "{instance}", type = "string", value = "{{instance}.PSY}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Exp", playerId = "{instance}", type = "string", value = "{{instance}.Exp}");
        儲存玩家狀態(category = "simple-rpg-test", key = "HP", playerId = "{instance}", type = "string", value = "{{instance}.HP}");
        儲存玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
    }
}
