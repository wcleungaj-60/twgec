        EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 60, duration = 500, color = "#000000", deltaHpType = "damage", deltaHpValue = "10 + {instance.AGI}*2", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        移動角色位置(actorId = "{instance}", x = "{x}/32", y = "{y}/32");
    }
    checks {
    }
}
