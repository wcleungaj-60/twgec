block 點擊提升一點力量 {
    __repeat__ = -1;
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("increase" + ("STR" + twge::to_string(1))));
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = 1);
    }
    actions {
        自定義::儲存Instance整數(key = "Point", value = ("{instance.Point} - " + twge::to_string(1)));
        自定義::儲存Instance整數(key = "STR", value = ("{instance." + ("STR" + ("} + " + twge::to_string(1)))));
        if((1 == 1)) {
            角色說話(actorId = "instance", text = ("成功提升一點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        } else if((1 == 10)) {
            角色說話(actorId = "instance", text = ("成功提升十點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        }
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
    }
}
