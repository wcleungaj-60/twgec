block 點擊重置能力 {
    __repeat__ = -1;
    triggers {
        告示牌按鈕(varName = "instance", buttonId = "ResetPoint");
    }
    actions {
        自定義::儲存Instance整數(key = "Point", value = "{instance.Level}*2+3");
        自定義::儲存Instance整數(key = "STR", value = 0);
        自定義::儲存Instance整數(key = "CON", value = 0);
        自定義::儲存Instance整數(key = "AGI", value = 0);
        自定義::儲存Instance整數(key = "INT", value = 0);
        自定義::儲存Instance整數(key = "PSY", value = 0);
        角色說話(actorId = "instance", text = "成功重設能力點，目前有{instance.Point}點能力點");
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
    }
}
block 等級提升 {
    __repeat__ = -1;
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.Exp}", op = ">=", rhs = "{instance.ExpNeeded}");
    }
    actions {
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = 文字::HTML等級提升, duration = 6000);
        自定義::儲存Instance整數(key = "Exp", value = "{instance.Exp}-{instance.ExpNeeded}");
        自定義::儲存Instance整數(key = "Level", value = "{instance.Level}+1");
        自定義::儲存Instance整數(key = "Point", value = "{instance.Point}+2");
        自定義::儲存Instance整數(key = "ExpNeeded", value = "{instance.Level}*2+4");
        自定義::儲存Instance整數(key = "HP", value = 公式::Instance血量);
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        自定義::上載Instance數據();
    }
}
block 回血 {
    __repeat__ = -1;
    __repeatInterval__ = 10000;
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
    }
    actions {
        角色加減血(actorCode = "instance", value = 公式::Instance恢復量);
    }
}
block 查看面板 {
    __repeat__ = -1;
    triggers {
        鍵盤按鍵(varName = "instance", key = "Z");
    }
    actions {
        角色說話(actorId = "{instance.id}", text = 文字::Instance訊息);
    }
}
block 技能火星領域 {
    __repeat__ = -1;
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比較數字(lhs = "{{clicker.id}.INT}+{{clicker.id}.PSY}", op = ">=", rhs = 5);
        比較數字(lhs = "{{clicker.id}.skillXCD}", op = "!=", rhs = 1);
    }
    actions {
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = "<span style='color: #912B2B'>火星領域</span>");
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        自定義::儲存Instance整數(key = "skillXCD", value = 1);
        EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
        EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = (2 * 64), duration = 10000, color = "#912B2B", lineWidth = 3);
        for(i in 1...30) {
            wait(duration = 300);
            EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = 公式::火星領域傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
        }
        wait(duration = 2000);
        自定義::儲存Instance整數(key = "skillXCD", value = 0);
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = "<span style='color: #912B2B'>火星領域冷卻完畢</span>");
    }
}
block 技能火星領域無效 {
    __repeat__ = -1;
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比較數字(lhs = "{{clicker.id}.INT}+{{clicker.id}.PSY}", op = "<", rhs = 5);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = "<span style='color: #912B2B'>智慧及精神之和大於等於5才可發動技能</span>");
    }
}
block 風杖光彈攻擊 {
    __repeat__ = -1;
    triggers {
        角色發動攻擊(weapon = 別名::武器風杖, varName = "instance");
    }
    actions {
        光彈特效(fromActor = "instance", toAngle = 公式::Instance角度, scale = "0.5", damage = 公式::風杖光彈傷害);
    }
}
block 玩家初始化 {
    __repeat__ = -1;
    triggers {
        角色進入戰場(actor = 角色::任何玩家, varName = "instance");
    }
    actions {
        自定義::儲存Instance整數(key = "STR", value = 0);
        自定義::儲存Instance整數(key = "CON", value = 0);
        自定義::儲存Instance整數(key = "AGI", value = 0);
        自定義::儲存Instance整數(key = "INT", value = 0);
        自定義::儲存Instance整數(key = "PSY", value = 0);
        自定義::儲存Instance整數(key = "Level", value = 1);
        自定義::儲存Instance整數(key = "Point", value = 5);
        自定義::儲存Instance整數(key = "Exp", value = 0);
        自定義::儲存Instance整數(key = "ExpNeeded", value = 6);
        自定義::儲存Instance整數(key = "HP", value = 100);
        取得玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", varName = "{instance}_savedBefore");
        人物裝備武器(actorCode = "instance", type = "fist", hand = 1);
        人物裝備武器(actorCode = "instance", type = "fist", hand = 2);
        角色說話(actorId = "instance", cleanTalk = true, text = "玩家初始中");
        設定角色屬性(actorId = "instance", attr = "group", value = "100");
        等待(duration = 500);
        自定義::儲存Instance整數(key = "completedInit", value = 1);
    }
}
block 遊戲初始化 {
    actions {
        迴避友軍攻擊();
        設定武器技能(weapon = 別名::武器風杖);
        設定武器技能(weapon = 別名::武器鐵劍);
        設定武器技能(weapon = 別名::武器匕首);
        自定義::設定雙向地圖傳送點(x1 = 19, y1 = 9, x2 = 21, y2 = 9);
        自定義::設定雙向地圖傳送點(x1 = 19, y1 = 10, x2 = 21, y2 = 10);
        自定義::設定雙向地圖傳送點(x1 = 30, y1 = 19, x2 = 30, y2 = 21);
        自定義::設定雙向地圖傳送點(x1 = 31, y1 = 19, x2 = 31, y2 = 21);
        地圖::生成地圖100n100(xOffset = 0, yOffset = 0);
        地圖::生成地圖101n100(xOffset = 21, yOffset = 0);
    }
}
