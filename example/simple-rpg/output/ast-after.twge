__thirdLocs__ = [Point(10,10)];
__lives__ = 9999;
__title__ = "RPG試驗";
__useDefaultItems__ = true;
__useCustomWeapons__ = true;
__customWeapons__ = [CustomWeapon(reference = "TWilightGameEventCompiler.weapon_wind_staff", code = "wind_staff", damage = 0, fireType = "單手橫劈", pivotOnHandDegree = 58, pivotOnHandX = 2, pivotOnHandY = 9, pivotOnHandXScale = "1.3", pivotOnHandYScale = "1.5", pivotOnIconDegree = -40, pivotOnIconX = 20, pivotOnIconY = 20),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_iron_sword", code = "iron_sword", damage = 0, fireType = "大刀砍劈", pivotOnHandDegree = 35, pivotOnHandX = -12, pivotOnIconDegree = -40, pivotOnIconX = 27, pivotOnIconY = 14),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_dagger", code = "dagger", damage = 0, fireType = "小刀前刺", pivotOnHandDegree = -92, pivotOnHandX = 34, pivotOnHandY = 24, pivotOnHandXScale = "0.7", pivotOnHandYScale = "0.8", pivotOnIconDegree = -140, pivotOnIconX = 34, pivotOnIconY = 16, weight = 3)];
__map__ = "CG.TWilightGameEventCompiler/rpg/simple_rpg.twmap";
__roomSize__ = 8;
block 下載老玩家數據 {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
        比較數字(lhs = "{instance.completedInit}", op = "==", rhs = 1);
        比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "1");
    }
    actions {
        儲存物件變數(key = "completedInit", object = "instance", type = "string", value = 2);
        取得玩家狀態(category = "simple-rpg-test", key = "Point", playerId = "{instance}", varName = "{instance}_Point");
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{{instance}_Point}");
        取得玩家狀態(category = "simple-rpg-test", key = "ExpNeeded", playerId = "{instance}", varName = "{instance}_ExpNeeded");
        儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = "{{instance}_ExpNeeded}");
        取得玩家狀態(category = "simple-rpg-test", key = "Level", playerId = "{instance}", varName = "{instance}_Level");
        儲存物件變數(key = "Level", object = "instance", type = "integer", value = "{{instance}_Level}");
        取得玩家狀態(category = "simple-rpg-test", key = "STR", playerId = "{instance}", varName = "{instance}_STR");
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = "{{instance}_STR}");
        取得玩家狀態(category = "simple-rpg-test", key = "CON", playerId = "{instance}", varName = "{instance}_CON");
        儲存物件變數(key = "CON", object = "instance", type = "integer", value = "{{instance}_CON}");
        取得玩家狀態(category = "simple-rpg-test", key = "AGI", playerId = "{instance}", varName = "{instance}_AGI");
        儲存物件變數(key = "AGI", object = "instance", type = "integer", value = "{{instance}_AGI}");
        取得玩家狀態(category = "simple-rpg-test", key = "INT", playerId = "{instance}", varName = "{instance}_INT");
        儲存物件變數(key = "INT", object = "instance", type = "integer", value = "{{instance}_INT}");
        取得玩家狀態(category = "simple-rpg-test", key = "PSY", playerId = "{instance}", varName = "{instance}_PSY");
        儲存物件變數(key = "PSY", object = "instance", type = "integer", value = "{{instance}_PSY}");
        取得玩家狀態(category = "simple-rpg-test", key = "Exp", playerId = "{instance}", varName = "{instance}_Exp");
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = "{{instance}_Exp}");
        取得玩家狀態(category = "simple-rpg-test", key = "HP", playerId = "{instance}", varName = "{instance}_HP");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "{{instance}_HP}");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = "4-3/(1+0.01*{instance.AGI})");
        設定角色屬性(actorId = "instance", attr = "weight", value = "3*pow(0.97,{instance.AGI})");
        角色加減血(actorCode = "instance", type = "heal", value = 9999);
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
    triggers {
    }
}
block 下載新玩家數據 {
    __repeat__ = -1;
    __label__ = "玩家";
