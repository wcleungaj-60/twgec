        EnhFF::廣義圓形範圍(actorId = "instance", radius = 128, duration = 10000, color = "#D16500", deltaHpType = "damage", deltaHpValue = "1 + {instance.STR}/2 + {instance.CON}/2", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101), lineWidth = 2);
    }
