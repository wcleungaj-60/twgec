    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = 10);
    }
    actions {
        自定義::儲存Instance整數(key = "Point", value = ("{instance.Point} - " + twge::to_string(10)));
        自定義::儲存Instance整數(key = "INT", value = ("{instance." + ("INT" + ("} + " + twge::to_string(10)))));
        if((10 == 1)) {
            角色說話(actorId = "instance", text = ("成功提升一點" + ("智慧" + "，尚餘{instance.Point}點能力點")));
        } else if((10 == 10)) {
            角色說話(actorId = "instance", text = ("成功提升十點" + ("智慧" + "，尚餘{instance.Point}點能力點")));
        }
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
    }
}
