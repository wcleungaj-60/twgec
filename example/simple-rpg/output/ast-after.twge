            光彈特效(fromActor = "instance", scale = "0.5", damage = "{instance.INT} + {instance.PSY}/2 + 10", toAngle = "{instance.bodyRotation}*180/3.14+16");
            光彈特效(fromActor = "instance", scale = "0.5", damage = "{instance.INT} + {instance.PSY}/2 + 10", toAngle = "{instance.bodyRotation}*180/3.14");
            光彈特效(fromActor = "instance", scale = "0.5", damage = "{instance.INT} + {instance.PSY}/2 + 10", toAngle = "{instance.bodyRotation}*180/3.14-16");
            光彈特效(fromActor = "instance", scale = "0.5", damage = "{instance.INT} + {instance.PSY}/2 + 10", toAngle = "{instance.bodyRotation}*180/3.14-32");
        }
        if(true) {
            EnhFF::廣義圓形範圍(actorId = "instance", radius = 128, duration = 10000, color = "#D16500", deltaHpType = "heal", deltaHpValue = "1 + {instance.CON}", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 100), lineWidth = 2);
            EnhFF::廣義圓形範圍(actorId = "instance", radius = 128, duration = 10000, color = "#D16500", deltaHpType = "damage", deltaHpValue = "1 + {instance.STR}/2 + {instance.CON}/2", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101), lineWidth = 2);
        }
        if(false) {
            EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
            EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 60, duration = 500, color = "#000000", deltaHpType = "damage", deltaHpValue = "10 + {instance.AGI}*2", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
            移動角色位置(actorId = "{instance}", x = "{x}/32", y = "{y}/32");
        }
    }
    checks {
    }
}
