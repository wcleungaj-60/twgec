block 觸發技能火星領域 {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比對字串(matchKind = "equal", str = "火星領域", value = "{{clicker.id}.XSkill}");
        比較數字(lhs = "{{clicker.id}.skillSparkAreaCD}", op = "!=", rhs = 1);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #912B2B'>火星領域</span>");
        儲存物件變數(key = "skillSparkAreaCD", object = "instance", type = "integer", value = 1);
        EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
        EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 128, duration = 10000, color = "#912B2B", lineWidth = 3);
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = "{instance.INT}/4+{instance.PSY}/6", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = "{instance.INT}/4+{instance.PSY}/6", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = "{instance.INT}/4+{instance.PSY}/6", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = "{instance.INT}/4+{instance.PSY}/6", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        wait(duration = 300);
