        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + ("#A57E00" + ("'>" + (別名::技能土靈召喚ZH + "</span>")))));
        自定義::儲存Instance整數(key = ("skill" + (別名::技能土靈召喚EN + "CD")), value = 1);
        if((別名::技能土靈召喚EN == 別名::技能火星領域EN)) {
            火星領域技能();
        }
        if((別名::技能土靈召喚EN == 別名::技能震撼EN)) {
            震撼技能();
        }
        if((別名::技能土靈召喚EN == 別名::技能土靈召喚EN)) {
            土靈召喚技能();
        }
        自定義::儲存Instance整數(key = ("skill" + (別名::技能土靈召喚EN + "CD")), value = 0);
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + ("#A57E00" + ("'>" + (別名::技能土靈召喚ZH + "冷卻完畢</span>")))));
    }
}
block 地圖初始化 {
    __label__ = "地圖";
    actions {
        自定義::設定雙向地圖傳送點(x1 = (地圖::size - 1), y1 = ((地圖::size / 2) - 1), x2 = 地圖::stride, y2 = ((地圖::size / 2) - 1));
        自定義::設定雙向地圖傳送點(x1 = (地圖::size - 1), y1 = (地圖::size / 2), x2 = 地圖::stride, y2 = (地圖::size / 2));
        自定義::設定雙向地圖傳送點(x1 = (地圖::stride + ((地圖::size / 2) - 1)), y1 = (地圖::size - 1), x2 = (地圖::stride + ((地圖::size / 2) - 1)), y2 = 地圖::stride);
        自定義::設定雙向地圖傳送點(x1 = (地圖::stride + (地圖::size / 2)), y1 = (地圖::size - 1), x2 = (地圖::stride + (地圖::size / 2)), y2 = 地圖::stride);
        地圖::生成地圖100n100(xOffset = 地圖::x座標100n100, yOffset = 地圖::y座標100n100);
        地圖::生成地圖101n100(xOffset = 地圖::x座標101n100, yOffset = 地圖::y座標101n100);
        地圖::生成地圖101n101(xOffset = 地圖::x座標101n101, yOffset = 地圖::y座標101n101);
    }
    checks {
    }
    triggers {
    }
}
block 點擊提升一點力量 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("increase" + ("STR" + twge::to_string(1))));
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = 1);
    }
    actions {
        自定義::儲存Instance整數(key = "Point", value = ("{instance.Point} - " + twge::to_string(1)));
        自定義::儲存Instance整數(key = "STR", value = ("{instance." + ("STR" + ("} + " + twge::to_string(1)))));
        if((1 == 1)) {
            角色說話(actorId = "instance", text = ("成功提升一點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        } else if((1 == 10)) {
            角色說話(actorId = "instance", text = ("成功提升十點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        }
        自定義::更新角色屬性(actorId = "instance");
        自定義::上載Instance數據();
    }
}
