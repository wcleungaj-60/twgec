__customWeapons__ = [CustomWeapon(reference = "TWilightGameEventCompiler.weapon_wind_staff", code = "wind_staff", damage = 0, fireType = "單手橫劈", pivotOnHandDegree = 58, pivotOnHandX = 2, pivotOnHandY = 9, pivotOnHandXScale = "1.3", pivotOnHandYScale = "1.5", pivotOnIconDegree = -40, pivotOnIconX = 20, pivotOnIconY = 20),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_iron_sword", code = "iron_sword", damage = 0, fireType = "大刀砍劈", pivotOnHandDegree = 35, pivotOnHandX = -12, pivotOnIconDegree = -40, pivotOnIconX = 27, pivotOnIconY = 14),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_dagger", code = "dagger", damage = 0, fireType = "小刀前刺", pivotOnHandDegree = -92, pivotOnHandX = 34, pivotOnHandY = 24, pivotOnHandXScale = "0.7", pivotOnHandYScale = "0.8", pivotOnIconDegree = -140, pivotOnIconX = 34, pivotOnIconY = 16, weight = 3)];
__map__ = "CG.TWilightGameEventCompiler/rpg/simple_rpg.twmap";
__roomSize__ = 8;
def 自定義::除錯(text) : actions {
    if(除錯模式) {
        print(type = "error", text = text);
    }
}
def 自定義::儲存Instance整數(key, value) : actions {
    儲存物件變數(key = key, object = "instance", type = "integer", value = value);
}
def 自定義::更新角色屬性(actorId) : actions {
    儲存物件變數(key = "HP", object = actorId, type = "integer", value = ("98 + 10*{" + (actorId + (".CON} + 2*{" + (actorId + ".Level}")))));
    設定角色屬性(actorId = actorId, attr = "maxHp", value = ("{" + (actorId + ".HP}")));
    設定角色屬性(actorId = actorId, attr = "closeWeaponSpeed", value = ("4-3/(1+0.01*{" + (actorId + ".AGI})")));
    設定角色屬性(actorId = actorId, attr = "weight", value = ("3*pow(0.97,{" + (actorId + ".AGI})")));
}
def 自定義::輔助::下載Instance數據(key) : actions {
    取得玩家狀態(category = 狀態讀寫密鑰, key = key, playerId = "{instance}", varName = ("{instance}_" + key));
    自定義::儲存Instance整數(key = key, value = ("{{instance}_" + (key + "}")));
}
def 自定義::輔助::上載Instance數據(key) : actions {
    儲存玩家狀態(category = 狀態讀寫密鑰, key = key, playerId = "{instance}", type = "string", value = ("{{instance}." + (key + "}")));
}
def 自定義::上載Instance數據() : actions {
    自定義::輔助::上載Instance數據(key = "Point");
    自定義::輔助::上載Instance數據(key = "ExpNeeded");
    自定義::輔助::上載Instance數據(key = "Level");
    自定義::輔助::上載Instance數據(key = "STR");
    自定義::輔助::上載Instance數據(key = "CON");
    自定義::輔助::上載Instance數據(key = "AGI");
    自定義::輔助::上載Instance數據(key = "INT");
    自定義::輔助::上載Instance數據(key = "PSY");
    自定義::輔助::上載Instance數據(key = "Exp");
    自定義::輔助::上載Instance數據(key = "HP");
    儲存玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
}
def 自定義::下載玩家數據泛型(hasSavedBefore) : block {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.completedInit}", op = "==", rhs = 1);
        if(hasSavedBefore) {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "1");
        } else {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "undefined");
        }
    }
    actions {
        儲存物件變數(key = "completedInit", object = "instance", type = "string", value = 2);
        if(hasSavedBefore) {
            自定義::輔助::下載Instance數據(key = "Point");
            自定義::輔助::下載Instance數據(key = "ExpNeeded");
            自定義::輔助::下載Instance數據(key = "Level");
            自定義::輔助::下載Instance數據(key = "STR");
            自定義::輔助::下載Instance數據(key = "CON");
            自定義::輔助::下載Instance數據(key = "AGI");
            自定義::輔助::下載Instance數據(key = "INT");
            自定義::輔助::下載Instance數據(key = "PSY");
            自定義::輔助::下載Instance數據(key = "Exp");
            自定義::輔助::下載Instance數據(key = "HP");
            自定義::更新角色屬性(actorId = "instance");
            角色加減血(actorCode = "instance", type = "heal", value = 9999);
        }
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
}
def 自定義::點擊裝備武器泛型(button, weapon) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("wear" + button));
    }
    actions {
        人物裝備武器(actorCode = "instance", type = weapon, hand = 1);
        人物裝備武器(actorCode = "instance", type = weapon, hand = 2);
    }
}
def 自定義::釋放技能泛型(weapon) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        發動技能(varName = "instance", weapon = weapon);
    }
    actions {
        if((weapon == 別名::武器風杖)) {
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+32"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = 公式::Instance角度);
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-32"));
        }
        if((weapon == 別名::武器鐵劍)) {
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "heal", deltaHpValue = 公式::鐵劍技能恢復, deltaHpCD = 1100, deltaHpTarget = 角色::任何友軍, lineWidth = 2);
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "damage", deltaHpValue = 公式::鐵劍技能傷害, deltaHpCD = 1100, deltaHpTarget = 角色::任何敵軍, lineWidth = 2);
        }
        if((weapon == 別名::武器匕首)) {
            EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
            EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 60, duration = 500, color = "#000000", deltaHpType = "damage", deltaHpValue = 公式::匕首技能傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
            移動角色位置(actorId = "{instance}", x = "{x}/32", y = "{y}/32");
        }
    }
}
def 自定義::武器物理攻擊泛型(weapon, value) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        角色受傷(actor = 角色::任何, actorVarName = "instance", hitter = 角色::任何, hitterVarName = "attacker", weapon = weapon);
    }
    actions {
        角色加減血(actorCode = "instance", casterCode = "attacker", type = "流血受傷", value = value);
    }
}
def 自定義::拾取經驗泛型(drop_item_code, exp) : block {
    __repeat__ = -1;
    __label__ = "怪物";
    triggers {
        拾取武器道具(actorVarname = "instance", matchKind = "equal", itemMatchCode = drop_item_code);
    }
    actions {
