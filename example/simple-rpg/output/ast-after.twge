block 觸發技能震撼 {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比對字串(matchKind = "equal", str = "震撼", value = "{{clicker.id}.XSkill}");
        比較數字(lhs = "{{clicker.id}.skillShockedCD}", op = "!=", rhs = 1);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #CC7700'>震撼</span>");
        儲存物件變數(key = "skillShockedCD", object = "instance", type = "integer", value = 1);
        EnhFF::廣義圓形範圍(actorId = "instance", radius = "60+10*{instance.CON}^0.5", duration = 2000, color = "#CC7700", deltaHpType = "damage", lineWidth = 3, deltaHpValue = "1+{instance.CON}/3", deltaHpCD = 4000, deltaHpTarget = ActorMatch(group = 101));
        wait(duration = 12000);
        儲存物件變數(key = "skillShockedCD", object = "instance", type = "integer", value = 0);
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #CC7700'>震撼冷卻完畢</span>");
    }
}
block 觸發技能土靈召喚 {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比對字串(matchKind = "equal", str = "土靈召喚", value = "{{clicker.id}.XSkill}");
        比較數字(lhs = "{{clicker.id}.skillSummonEarthSpiritCD}", op = "!=", rhs = 1);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #A57E00'>土靈召喚</span>");
        儲存物件變數(key = "skillSummonEarthSpiritCD", object = "instance", type = "integer", value = 1);
        儲存全域變數(key = "tmp", type = "int", value = "100+{instance.PSY}*2");
        新增角色(name = "土靈({tmp})", id = "earthSpirit*", camp = "第三", hp = "100+{instance.PSY}*2", x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 100, strength = "10+{instance.PSY}/5", role = "不動佛");
        跟隨人物(actorId = "actor", type = "跟隨人物", targetId = "{instance}");
        wait(duration = 35000);
        角色消失(actorId = "actor");
        wait(duration = 5000);
        儲存物件變數(key = "skillSummonEarthSpiritCD", object = "instance", type = "integer", value = 0);
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #A57E00'>土靈召喚冷卻完畢</span>");
    }
}
block 地圖初始化 {
    __label__ = "地圖";
    actions {
        設定地圖傳送點(fromX = 19, fromY = 9, toX = 27, toY = 9, direction = "右");
        設定地圖傳送點(fromX = 27, fromY = 9, toX = 19, toY = 9, direction = "左");
        設定地圖傳送點(fromX = 19, fromY = 10, toX = 27, toY = 10, direction = "右");
        設定地圖傳送點(fromX = 27, fromY = 10, toX = 19, toY = 10, direction = "左");
        設定地圖傳送點(fromX = 36, fromY = 19, toX = 36, toY = 27, direction = "下");
        設定地圖傳送點(fromX = 36, fromY = 27, toX = 36, toY = 19, direction = "上");
        設定地圖傳送點(fromX = 37, fromY = 19, toX = 37, toY = 27, direction = "下");
        設定地圖傳送點(fromX = 37, fromY = 27, toX = 37, toY = 19, direction = "上");
        新增地圖物件(x = 5, y = 0, object = "草地");
        新增地圖物件(x = 6, y = 0, object = "草地");
        新增地圖物件(x = 13, y = 1, object = "草地");
        新增地圖物件(x = 14, y = 1, object = "草地");
        新增地圖物件(x = 15, y = 1, object = "草地");
        新增地圖物件(x = 12, y = 2, object = "大箱子", walkable = false);
        新增地圖物件(x = 4, y = 3, object = "5x4橫向房子", walkable = false);
        新增地圖物件(x = 7, y = 4, object = "草地");
        新增地圖物件(x = 8, y = 4, object = "草地");
        新增地圖物件(x = 12, y = 4, object = "小箱子");
        新增告示牌(x = 12, y = 4, rotation = 180, text = "【火星領域】\n在滑鼠指定範圍內持續出現星火\n - 星火傷害: 智慧÷4+精神÷6\n冷卻10秒", buttons = [Button(id = "setXSparkArea", text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
        新增地圖物件(x = 15, y = 4, object = "5x4縱向房子", walkable = false);
        新增地圖物件(x = 7, y = 5, object = "草地");
        新增地圖物件(x = 12, y = 5, object = "小箱子");
        新增告示牌(x = 12, y = 5, rotation = 180, text = "【震撼】\n對自身附近的敵人造成傷害\n體質越高，威力及範圍越大\n - 震撼傷害: 1+體質÷3\n - 震撼範圍: 60+10×體質^0.5\n冷卻10秒", buttons = [Button(id = "setXShocked", text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
        新增角色(name = "技能商人", id = "npc02*", camp = "第三", x = 13, y = 5, rotation = 180, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "赤焰精靈");
        新增地圖物件(x = 2, y = 6, object = "大箱子", walkable = false);
        新增角色(name = "武器商人", id = "npc01*", camp = "第三", x = 5, y = 6, rotation = 90, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "隱居士");
        新增地圖物件(x = 12, y = 6, object = "小箱子");
        新增告示牌(x = 12, y = 6, rotation = 180, text = "【土靈召喚】\n生成一直存在35秒的土靈為你戰鬥\n - 土靈血量: 100+精神×2\n - 土靈傷害: 10+精神÷5\n冷卻40秒", buttons = [Button(id = "setXSummonEarthSpirit", text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
        新增地圖物件(x = 4, y = 7, object = "小箱子");
        新增告示牌(x = 4, y = 7, rotation = 90, text = "【風杖】\n【普通攻擊】\n - 武器傷害: 5+力量÷2\n - 光彈傷害: 10+智慧+精神÷2\n【技能】散射釋出五發光彈\n - 光彈傷害: 10+智慧+精神÷2", buttons = [Button(id = "wearWindStaff", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
        新增地圖物件(x = 5, y = 7, object = "小箱子");
        新增告示牌(x = 5, y = 7, rotation = 90, text = "【匕首】\n【普通攻擊】\n - 武器傷害: 10+力量×2+敏捷\n【技能】移動至滑鼠指定位置，並在目的範圍內造成傷害\n - 範圍傷害：10+敏捷×2", buttons = [Button(id = "wearDagger", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
        新增地圖物件(x = 6, y = 7, object = "小箱子");
