            儲存物件變數(key = "STR", object = "instance", type = "integer", value = "{{instance}_STR}");
            取得玩家狀態(category = "simple-rpg-test", key = "CON", playerId = "{instance}", varName = "{instance}_CON");
            儲存物件變數(key = "CON", object = "instance", type = "integer", value = "{{instance}_CON}");
            取得玩家狀態(category = "simple-rpg-test", key = "AGI", playerId = "{instance}", varName = "{instance}_AGI");
            儲存物件變數(key = "AGI", object = "instance", type = "integer", value = "{{instance}_AGI}");
            取得玩家狀態(category = "simple-rpg-test", key = "INT", playerId = "{instance}", varName = "{instance}_INT");
            儲存物件變數(key = "INT", object = "instance", type = "integer", value = "{{instance}_INT}");
            取得玩家狀態(category = "simple-rpg-test", key = "PSY", playerId = "{instance}", varName = "{instance}_PSY");
            儲存物件變數(key = "PSY", object = "instance", type = "integer", value = "{{instance}_PSY}");
            取得玩家狀態(category = "simple-rpg-test", key = "Exp", playerId = "{instance}", varName = "{instance}_Exp");
            儲存物件變數(key = "Exp", object = "instance", type = "integer", value = "{{instance}_Exp}");
            取得玩家狀態(category = "simple-rpg-test", key = "HP", playerId = "{instance}", varName = "{instance}_HP");
            儲存物件變數(key = "HP", object = "instance", type = "integer", value = "{{instance}_HP}");
            儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
            設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
            設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = "4-3/(1+0.01*{instance.AGI})");
            設定角色屬性(actorId = "instance", attr = "weight", value = "3*pow(0.97,{instance.AGI})");
            角色加減血(actorCode = "instance", type = "heal", value = 9999);
        }
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
    triggers {
    }
}
