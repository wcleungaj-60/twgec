block 回血 {
    __repeat__ = -1;
    __repeatInterval__ = 10000;
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
    }
    actions {
        角色加減血(actorCode = "instance", value = "1 + {instance.PSY} + {instance.CON}/2");
    }
    triggers {
    }
}
block 查看面板 {
    __repeat__ = -1;
    triggers {
        鍵盤按鍵(varName = "instance", key = "Z");
    }
    actions {
        角色說話(actorId = "{instance.id}", text = "【Lv{{instance.id}.Level}】\nExp:{{instance.id}.Exp}/{{instance.id}.ExpNeeded}\n尚餘能力點：{{instance.id}.Point}\n力量：{{instance.id}.STR}\n體質：{{instance.id}.CON}\n敏捷：{{instance.id}.AGI}\n智慧：{{instance.id}.INT}\n精神：{{instance.id}.PSY}");
    }
    checks {
    }
}
block 技能火星領域 {
    __repeat__ = -1;
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比較數字(lhs = "{{clicker.id}.INT}+{{clicker.id}.PSY}", op = ">=", rhs = 5);
        比較數字(lhs = "{{clicker.id}.skillXCD}", op = "!=", rhs = 1);
    }
    actions {
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: #912B2B'>火星領域</span>");
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        儲存物件變數(key = "skillXCD", object = "instance", type = "integer", value = 1);
        EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
