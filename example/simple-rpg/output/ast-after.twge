block 回血 {
    __repeat__ = -1;
    __repeatInterval__ = 10000;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
    }
    actions {
        角色加減血(actorCode = "instance", value = "1 + {instance.PSY} + {instance.CON}/2");
    }
    triggers {
    }
}
block 查看面板 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        鍵盤按鍵(varName = "instance", key = "Z");
    }
    actions {
        角色說話(actorId = "{instance.id}", text = "【Lv{{instance.id}.Level}】\nExp:{{instance.id}.Exp}/{{instance.id}.ExpNeeded}\n尚餘能力點：{{instance.id}.Point}\n力量：{{instance.id}.STR}\n體質：{{instance.id}.CON}\n敏捷：{{instance.id}.AGI}\n智慧：{{instance.id}.INT}\n精神：{{instance.id}.PSY}\n\n按鍵X技能: 【{{instance.id}.XSkill}】");
    }
    checks {
    }
}
block 玩家初始化 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        角色進入戰場(actor = ActorMatch(controller = "player"), varName = "instance");
    }
    actions {
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "CON", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "AGI", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "INT", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "PSY", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "Level", object = "instance", type = "integer", value = 1);
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = 5);
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = 6);
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = 100);
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = "無");
        取得玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", varName = "{instance}_savedBefore");
        人物裝備武器(actorCode = "instance", type = "fist", hand = 1);
        人物裝備武器(actorCode = "instance", type = "fist", hand = 2);
        角色說話(actorId = "instance", cleanTalk = true, text = "玩家初始中");
        設定角色屬性(actorId = "instance", attr = "group", value = "100");
        等待(duration = 500);
        儲存物件變數(key = "completedInit", object = "instance", type = "integer", value = 1);
    }
    checks {
    }
}
block 遊戲初始化 {
    actions {
        迴避友軍攻擊();
    }
    checks {
    }
    triggers {
    }
}
