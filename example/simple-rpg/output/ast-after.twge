block 點擊提升一點力量 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("increase" + ("STR" + twge::to_string(1))));
    }
    checks {
        比較數字(lhs = "{instance.Point}", op = ">=", rhs = 1);
    }
    actions {
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = ("{instance.Point} - " + twge::to_string(1)));
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = ("{instance." + ("STR" + ("} + " + twge::to_string(1)))));
        if((1 == 1)) {
            角色說話(actorId = "instance", text = ("成功提升一點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        } else if((1 == 10)) {
            角色說話(actorId = "instance", text = ("成功提升十點" + ("力量" + "，尚餘{instance.Point}點能力點")));
        }
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = ("98 + 10*{" + ("instance" + (".CON} + 2*{" + ("instance" + ".Level}")))));
        設定角色屬性(actorId = "instance", attr = "maxHp", value = ("{" + ("instance" + ".HP}")));
        設定角色屬性(actorId = "instance", attr = "closeWeaponSpeed", value = ("4-3/(1+0.01*{" + ("instance" + ".AGI})")));
        設定角色屬性(actorId = "instance", attr = "weight", value = ("3*pow(0.97,{" + ("instance" + ".AGI})")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "Point", playerId = "{instance}", type = "string", value = ("{{instance}." + ("Point" + "}")));
        儲存玩家狀態(category = 狀態讀寫密鑰, key = "ExpNeeded", playerId = "{instance}", type = "string", value = ("{{instance}." + ("ExpNeeded" + "}")));
