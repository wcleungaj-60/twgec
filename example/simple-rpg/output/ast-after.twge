__skydowLocs__ = 出生點;
__royalLocs__ = 出生點;
__thirdLocs__ = 出生點;
__lives__ = 9999;
__title__ = "RPG試驗";
__useDefaultItems__ = true;
__useCustomWeapons__ = true;
__customWeapons__ = [CustomWeapon(reference = "TWilightGameEventCompiler.weapon_wind_staff", code = "wind_staff", damage = 0, fireType = "單手橫劈", pivotOnHandDegree = 58, pivotOnHandX = 2, pivotOnHandY = 9, pivotOnHandXScale = "1.3", pivotOnHandYScale = "1.5", pivotOnIconDegree = -40, pivotOnIconX = 20, pivotOnIconY = 20),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_iron_sword", code = "iron_sword", damage = 0, fireType = "大刀砍劈", pivotOnHandDegree = 35, pivotOnHandX = -12, pivotOnIconDegree = -40, pivotOnIconX = 27, pivotOnIconY = 14),CustomWeapon(reference = "TWilightGameEventCompiler.weapon_dagger", code = "dagger", damage = 0, fireType = "小刀前刺", pivotOnHandDegree = -92, pivotOnHandX = 34, pivotOnHandY = 24, pivotOnHandXScale = "0.7", pivotOnHandYScale = "0.8", pivotOnIconDegree = -140, pivotOnIconX = 34, pivotOnIconY = 16, weight = 3)];
__map__ = "CG.TWilightGameEventCompiler/rpg/simple_rpg.twmap";
__roomSize__ = 8;
def 自定義::除錯(text) : actions {
    if(除錯模式) {
        print(type = "error", text = text);
    }
}
def 自定義::儲存Instance整數(key, value) : actions {
    儲存物件變數(key = key, object = "instance", type = "integer", value = value);
}
def 自定義::更新角色屬性(actorId) : actions {
    儲存物件變數(key = "HP", object = actorId, type = "integer", value = ("98 + 10*{" + (actorId + (".CON} + 2*{" + (actorId + ".Level}")))));
    設定角色屬性(actorId = actorId, attr = "maxHp", value = ("{" + (actorId + ".HP}")));
    設定角色屬性(actorId = actorId, attr = "closeWeaponSpeed", value = ("4-3/(1+0.01*{" + (actorId + ".AGI})")));
    設定角色屬性(actorId = actorId, attr = "weight", value = ("3*pow(0.97,{" + (actorId + ".AGI})")));
}
def 自定義::輔助::下載Instance數據(key) : actions {
    取得玩家狀態(category = 狀態讀寫密鑰, key = key, playerId = "{instance}", varName = ("{instance}_" + key));
    自定義::儲存Instance整數(key, ("{{instance}_" + (key + "}")));
}
def 自定義::輔助::上載Instance數據(key) : actions {
    儲存玩家狀態(category = 狀態讀寫密鑰, key = key, playerId = "{instance}", type = "string", value = ("{{instance}." + (key + "}")));
}
def 自定義::上載Instance數據() : actions {
    自定義::輔助::上載Instance數據("Point");
    自定義::輔助::上載Instance數據("ExpNeeded");
    自定義::輔助::上載Instance數據("Level");
    自定義::輔助::上載Instance數據("STR");
    自定義::輔助::上載Instance數據("CON");
    自定義::輔助::上載Instance數據("AGI");
    自定義::輔助::上載Instance數據("INT");
    自定義::輔助::上載Instance數據("PSY");
    自定義::輔助::上載Instance數據("Exp");
    自定義::輔助::上載Instance數據("HP");
    儲存玩家狀態(category = 狀態讀寫密鑰, key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
}
def 自定義::下載玩家數據泛型(hasSavedBefore) : block {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = 角色::任何玩家, varname = "instance");
        比較數字(lhs = "{instance.completedInit}", op = "==", rhs = 1);
        if(hasSavedBefore) {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "1");
        } else {
            比對字串(str = "{{instance}_savedBefore}", matchKind = "equal", value = "undefined");
        }
    }
    actions {
        儲存物件變數(key = "completedInit", object = "instance", type = "string", value = 2);
        if(hasSavedBefore) {
            自定義::輔助::下載Instance數據("Point");
            自定義::輔助::下載Instance數據("ExpNeeded");
            自定義::輔助::下載Instance數據("Level");
            自定義::輔助::下載Instance數據("STR");
            自定義::輔助::下載Instance數據("CON");
            自定義::輔助::下載Instance數據("AGI");
            自定義::輔助::下載Instance數據("INT");
            自定義::輔助::下載Instance數據("PSY");
            自定義::輔助::下載Instance數據("Exp");
            自定義::輔助::下載Instance數據("HP");
            自定義::更新角色屬性("instance");
            角色加減血(actorCode = "instance", type = "heal", value = 9999);
        }
        角色說話(actorId = "instance", cleanTalk = true, text = "初始化完畢");
    }
}
def 自定義::點擊裝備武器泛型(button, weapon) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("wear" + button));
    }
    actions {
        人物裝備武器(actorCode = "instance", type = weapon, hand = 1);
        人物裝備武器(actorCode = "instance", type = weapon, hand = 2);
    }
}
def 自定義::釋放技能泛型(weapon) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        發動技能(varName = "instance", weapon = weapon);
    }
    actions {
        if((weapon == 別名::武器風杖)) {
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+32"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = 公式::Instance角度);
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-32"));
        }
        if((weapon == 別名::武器鐵劍)) {
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "heal", deltaHpValue = 公式::鐵劍技能恢復, deltaHpCD = 1100, deltaHpTarget = 角色::任何友軍, lineWidth = 2);
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "damage", deltaHpValue = 公式::鐵劍技能傷害, deltaHpCD = 1100, deltaHpTarget = 角色::任何敵軍, lineWidth = 2);
        }
        if((weapon == 別名::武器匕首)) {
            EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
            EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 60, duration = 500, color = "#000000", deltaHpType = "damage", deltaHpValue = 公式::匕首技能傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
            移動角色位置(actorId = "{instance}", x = "{x}/32", y = "{y}/32");
        }
    }
}
def 自定義::武器物理攻擊泛型(weapon, value) : block {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        角色受傷(actor = 角色::任何, actorVarName = "instance", hitter = 角色::任何, hitterVarName = "attacker", weapon = weapon);
    }
    actions {
        角色加減血(actorCode = "instance", casterCode = "attacker", type = "流血受傷", value = value);
    }
}
def 自定義::拾取經驗泛型(drop_item_code, exp) : block {
    __repeat__ = -1;
    __label__ = "怪物";
    triggers {
        拾取武器道具(actorVarname = "instance", matchKind = "equal", itemMatchCode = drop_item_code);
    }
    actions {
        自定義::儲存Instance整數("Exp", ("{instance.Exp}+" + twge::to_string(exp)));
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: green'>EXP+" + (twge::to_string(exp) + "</span>")));
        自定義::上載Instance數據();
    }
}
def 自定義::野獸死亡泛型(actor_id, drop_item_code, drop_item_type) : block {
    __repeat__ = -1;
    __label__ = "怪物";
    triggers {
        角色死亡(actor = ActorMatch(id = actor_id), varName = "instance");
    }
    actions {
        新增放置可拾取道具(itemCode = drop_item_code, x = (公式::InstanceX坐標 + "-0.5"), y = (公式::InstanceY坐標 + "-0.5"), type = drop_item_type);
    }
}
def 自定義::野獸重生泛型(interval, max_num, actor_id, name, x, y, hp, strength, role) : block {
    __repeat__ = -1;
    __repeatInterval__ = interval;
    __delay__ = 1000;
    __label__ = "怪物";
    checks {
        計算人數(actor = ActorMatch(id = actor_id, matchKind = "contain"), op = "<", value = max_num);
    }
    actions {
        新增角色(name = name, id = (actor_id + "*"), camp = "第三", hp = hp, x = x, y = y, range = 10, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 101, strength = strength, role = role);
        跟隨人物(actorId = "actor", type = "跟隨自己");
    }
}
def 自定義::點擊設定技能泛型(name, nameZh) : block {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        告示牌按鈕(varName = "instance", buttonId = ("setX" + name));
    }
    actions {
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = nameZh);
    }
}
def 火星領域技能() : actions {
    EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
    EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = (2 * 64), duration = 10000, color = "#912B2B", lineWidth = 3);
    for(i in 1...30) {
        wait(duration = 300);
        EnhFF::廣義圓形範圍(x = "{x}+random(-64,64)", y = "{y}+random(-64,64)", radius = 40, duration = 500, color = "#FF0F0F", deltaHpType = "damage", deltaHpValue = 公式::火星領域傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
    }
    wait(duration = 10000);
}
def 震撼技能() : actions {
    EnhFF::廣義圓形範圍(actorId = "instance", radius = 公式::震撼範圍, duration = 2000, color = "#CC7700", deltaHpType = "damage", lineWidth = 3, deltaHpValue = 公式::震撼傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
    wait(duration = 12000);
}
def 土靈召喚技能() : actions {
    儲存全域變數(key = "tmp", type = "int", value = 公式::土靈召喚血量);
    新增角色(name = "土靈({tmp})", id = "earthSpirit*", camp = "第三", hp = 公式::土靈召喚血量, x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, localVarname = "actor", weapon1 = "fist", weapon2 = "fist", teamId = 100, strength = 公式::土靈召喚傷害, role = "不動佛");
    跟隨人物(actorId = "actor", type = "跟隨人物", targetId = "{instance}");
    wait(duration = 35000);
    角色消失(actorId = "actor");
    wait(duration = 5000);
}
def 自定義::觸發技能泛型(name, nameZh, color) : block {
    __repeat__ = -1;
    __label__ = "技能";
    triggers {
        鍵盤按鍵(varName = "clicker", key = "X");
    }
    checks {
        比對字串(matchKind = "equal", str = nameZh, value = "{{clicker.id}.XSkill}");
        比較數字(lhs = ("{{clicker.id}.skill" + (name + "CD}")), op = "!=", rhs = 1);
    }
    actions {
        setGlobal(key = "instance", type = "string", value = "{clicker.id}");
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + (color + ("'>" + (nameZh + "</span>")))));
        自定義::儲存Instance整數(("skill" + (name + "CD")), 1);
        if((name == 別名::技能火星領域EN)) {
            火星領域技能();
        }
        if((name == 別名::技能震撼EN)) {
            震撼技能();
        }
        if((name == 別名::技能土靈召喚EN)) {
            土靈召喚技能();
        }
        自定義::儲存Instance整數(("skill" + (name + "CD")), 0);
        地圖標示文字(x = 公式::InstanceX坐標, y = 公式::InstanceY坐標, html = true, text = ("<span style='color: " + (color + ("'>" + (nameZh + "冷卻完畢</span>")))));
    }
}
def 地圖::新增能力點告示牌(x, y, text, type) : actions {
    新增地圖物件(x = x, y = y, object = "石椅");
    新增告示牌(x = x, y = y, rotation = 270, text = text, buttons = [Button(id = ("increase" + (type + "1")), text = "提升一點"),Button(id = ("increase" + (type + "10")), text = "提升十點")]);
}
def 地圖::生成地圖配置(x, y, object) : actions {
    if(((object == "---") || (object == " . "))) {
    } else if((object == "SP0")) {
        新增地圖物件(x = x, y = y, object = "石椅");
        新增告示牌(x = x, y = y, rotation = 0, text = "【重置能力點分配】", buttons = [Button(id = "ResetPoint", text = "確認")]);
    } else if((object == "SP1")) {
        地圖::新增能力點告示牌(x, y, 文字::力量描述, "STR");
    } else if((object == "SP2")) {
        地圖::新增能力點告示牌(x, y, 文字::體質描述, "CON");
    } else if((object == "SP3")) {
        地圖::新增能力點告示牌(x, y, 文字::敏捷描述, "AGI");
    } else if((object == "SP4")) {
        地圖::新增能力點告示牌(x, y, 文字::智慧描述, "INT");
    } else if((object == "SP5")) {
        地圖::新增能力點告示牌(x, y, 文字::精神描述, "PSY");
    } else if((object == "SW1")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 90, text = 文字::風杖描述, buttons = [Button(id = "wearWindStaff", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SW2")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = 5, y = 7, rotation = 90, text = 文字::匕首描述, buttons = [Button(id = "wearDagger", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SW3")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = 6, y = 7, rotation = 90, text = 文字::鐵劍描述, buttons = [Button(id = "wearIronSword", text = "裝備"),Button(id = "wearNone", text = "卸下")]);
    } else if((object == "SS1")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::火星領域描述, buttons = [Button(id = ("setX" + 別名::技能火星領域EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "SS2")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::震撼描述, buttons = [Button(id = ("setX" + 別名::技能震撼EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "SS3")) {
        新增地圖物件(x = x, y = y, object = "小箱子");
        新增告示牌(x = x, y = y, rotation = 180, text = 文字::土靈召喚, buttons = [Button(id = ("setX" + 別名::技能土靈召喚EN), text = "設置於X鍵"),Button(id = "setXNone", text = "卸下")]);
    } else if((object == "NP1")) {
        新增角色(name = "武器商人", id = "npc01*", camp = "第三", x = x, y = y, rotation = 90, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "隱居士");
    } else if((object == "NP2")) {
        新增角色(name = "技能商人", id = "npc02*", camp = "第三", x = x, y = y, rotation = 180, weapon1 = "fist", weapon2 = "fist", teamId = 100, role = "赤焰精靈");
    } else if((object == "LBx")) {
        新增地圖物件(x = x, y = y, object = "大箱子", walkable = false);
    } else if((object == "SBx")) {
        新增地圖物件(x = x, y = y, object = "小箱子", walkable = false);
    } else if((object == "H00")) {
        新增地圖物件(x = x, y = y, object = "5x4橫向房子", walkable = false);
    } else if((object == "H01")) {
        新增地圖物件(x = x, y = y, object = "5x4縱向房子", walkable = false);
    } else if((object == "***")) {
        新增地圖物件(x = x, y = y, object = "草地");
    } else if((object == "t00")) {
        新增地圖物件(x = x, y = y, object = "3x3綠樹");
    } else if((object == "ExN")) {
        新增地圖物件(x = x, y = y, object = "白光(上)");
    } else if((object == "ExE")) {
        新增地圖物件(x = x, y = y, object = "白光(右)");
    } else if((object == "ExS")) {
        新增地圖物件(x = x, y = y, object = "白光(下)");
    } else if((object == "ExW")) {
        新增地圖物件(x = x, y = y, object = "白光(左)");
    } else {
        print(text = ("無效Object:" + object), type = "error");
    }
}
def 地圖::生成地圖100n100(xOffset, yOffset) : actions {
    for(map_row in 0...(twge::get_length(地圖::新手村100n100) - 1)) {
        for(map_col in 0...((twge::get_length(twge::get_index(地圖::新手村100n100, map_row)) / 3) - 1)) {
            地圖::生成地圖配置((map_col + xOffset), (map_row + yOffset), (twge::get_index(twge::get_index(地圖::新手村100n100, map_row), ((map_col * 3) + 0)) + (twge::get_index(twge::get_index(地圖::新手村100n100, map_row), ((map_col * 3) + 1)) + twge::get_index(twge::get_index(地圖::新手村100n100, map_row), ((map_col * 3) + 2)))));
        }
    }
}
