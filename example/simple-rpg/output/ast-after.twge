block 等級提升 {
    __repeat__ = -1;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
        比較數字(lhs = "{instance.Exp}", op = ">=", rhs = "{instance.ExpNeeded}");
    }
    actions {
        地圖標示文字(x = "{instance.gamePosition.x}/32", y = "{instance.gamePosition.y}/32", html = true, text = "<span style='color: green'>Level Up</span>", duration = 6000);
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = "{instance.Exp}-{instance.ExpNeeded}");
        儲存物件變數(key = "Level", object = "instance", type = "integer", value = "{instance.Level}+1");
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = "{instance.Point}+2");
        儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = "{instance.Level}*2+4");
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = "98 + 10*{instance.CON} + 2*{instance.Level}");
        設定角色屬性(actorId = "instance", attr = "maxHp", value = "{instance.HP}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Point", playerId = "{instance}", type = "string", value = "{{instance}.Point}");
        儲存玩家狀態(category = "simple-rpg-test", key = "ExpNeeded", playerId = "{instance}", type = "string", value = "{{instance}.ExpNeeded}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Level", playerId = "{instance}", type = "string", value = "{{instance}.Level}");
        儲存玩家狀態(category = "simple-rpg-test", key = "STR", playerId = "{instance}", type = "string", value = "{{instance}.STR}");
        儲存玩家狀態(category = "simple-rpg-test", key = "CON", playerId = "{instance}", type = "string", value = "{{instance}.CON}");
        儲存玩家狀態(category = "simple-rpg-test", key = "AGI", playerId = "{instance}", type = "string", value = "{{instance}.AGI}");
        儲存玩家狀態(category = "simple-rpg-test", key = "INT", playerId = "{instance}", type = "string", value = "{{instance}.INT}");
        儲存玩家狀態(category = "simple-rpg-test", key = "PSY", playerId = "{instance}", type = "string", value = "{{instance}.PSY}");
        儲存玩家狀態(category = "simple-rpg-test", key = "Exp", playerId = "{instance}", type = "string", value = "{{instance}.Exp}");
        儲存玩家狀態(category = "simple-rpg-test", key = "HP", playerId = "{instance}", type = "string", value = "{{instance}.HP}");
        儲存玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", type = "integer", value = "1");
    }
    triggers {
    }
}
block 回血 {
    __repeat__ = -1;
    __repeatInterval__ = 10000;
    __label__ = "玩家";
    checks {
        找出所有角色(actor = ActorMatch(controller = "player"), varname = "instance");
    }
    actions {
        角色加減血(actorCode = "instance", value = "1 + {instance.PSY} + {instance.CON}/2");
    }
    triggers {
    }
}
block 查看面板 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        鍵盤按鍵(varName = "instance", key = "Z");
    }
    actions {
        角色說話(actorId = "{instance.id}", text = "【Lv{{instance.id}.Level}】\nExp:{{instance.id}.Exp}/{{instance.id}.ExpNeeded}\n尚餘能力點：{{instance.id}.Point}\n力量：{{instance.id}.STR}\n體質：{{instance.id}.CON}\n敏捷：{{instance.id}.AGI}\n智慧：{{instance.id}.INT}\n精神：{{instance.id}.PSY}\n\n按鍵X技能: 【{{instance.id}.XSkill}】");
    }
    checks {
    }
}
block 玩家初始化 {
    __repeat__ = -1;
    __label__ = "玩家";
    triggers {
        角色進入戰場(actor = ActorMatch(controller = "player"), varName = "instance");
    }
    actions {
        儲存物件變數(key = "STR", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "CON", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "AGI", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "INT", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "PSY", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "Level", object = "instance", type = "integer", value = 1);
        儲存物件變數(key = "Point", object = "instance", type = "integer", value = 5);
        儲存物件變數(key = "Exp", object = "instance", type = "integer", value = 0);
        儲存物件變數(key = "ExpNeeded", object = "instance", type = "integer", value = 6);
        儲存物件變數(key = "HP", object = "instance", type = "integer", value = 100);
        儲存物件變數(key = "XSkill", object = "instance", type = "string", value = "無");
        取得玩家狀態(category = "simple-rpg-test", key = "savedBefore", playerId = "{instance}", varName = "{instance}_savedBefore");
        人物裝備武器(actorCode = "instance", type = "fist", hand = 1);
        人物裝備武器(actorCode = "instance", type = "fist", hand = 2);
        角色說話(actorId = "instance", cleanTalk = true, text = "玩家初始中");
        設定角色屬性(actorId = "instance", attr = "group", value = "100");
        等待(duration = 500);
        儲存物件變數(key = "completedInit", object = "instance", type = "integer", value = 1);
    }
    checks {
    }
}
block 遊戲初始化 {
    actions {
        迴避友軍攻擊();
    }
    checks {
    }
    triggers {
    }
}
