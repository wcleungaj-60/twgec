block 釋放技能風杖 {
    __repeat__ = -1;
    __label__ = "武器";
    triggers {
        發動技能(varName = "instance", weapon = 別名::武器風杖);
    }
    actions {
        if((別名::武器風杖 == 別名::武器風杖)) {
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+32"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "+16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = 公式::Instance角度);
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-16"));
            光彈特效(fromActor = "instance", scale = "0.5", damage = 公式::風杖光彈傷害, toAngle = (公式::Instance角度 + "-32"));
        }
        if((別名::武器風杖 == 別名::武器鐵劍)) {
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "heal", deltaHpValue = 公式::鐵劍技能恢復, deltaHpCD = 1100, deltaHpTarget = 角色::任何友軍, lineWidth = 2);
            EnhFF::廣義圓形範圍(actorId = "instance", radius = (4 * 32), duration = 10000, color = "#D16500", deltaHpType = "damage", deltaHpValue = 公式::鐵劍技能傷害, deltaHpCD = 1100, deltaHpTarget = 角色::任何敵軍, lineWidth = 2);
        }
        if((別名::武器風杖 == 別名::武器匕首)) {
            EnhFF::玩家滑鼠座標(actorId = "{instance}", varX = "x", varY = "y");
            EnhFF::廣義圓形範圍(x = "{x}", y = "{y}", radius = 60, duration = 500, color = "#000000", deltaHpType = "damage", deltaHpValue = 公式::匕首技能傷害, deltaHpCD = 4000, deltaHpTarget = 角色::任何敵軍);
            移動角色位置(actorId = "{instance}", x = "{x}/32", y = "{y}/32");
        }
    }
}
